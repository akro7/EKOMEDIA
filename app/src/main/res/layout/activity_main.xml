<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/eko_bg">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="56dp"
            android:paddingBottom="32dp">

            <!-- ══ Header ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EKO MEDIA"
                        android:textColor="@color/eko_text"
                        android:textSize="36sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="by @A_KOJO • 🪷♥️👻🤍🪷"
                        android:textColor="@color/eko_accent"
                        android:textSize="11sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Red divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/eko_accent"
                android:alpha="0.4"
                android:layout_marginBottom="20dp" />

            <!-- ══ URL Input Card ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/eko_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔗 رابط الفيديو"
                        android:textColor="@color/eko_accent"
                        android:textSize="11sp"
                        android:letterSpacing="0.15"
                        android:layout_marginBottom="10dp" />

                    <EditText
                        android:id="@+id/etUrl"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:hint="@string/hint_url"
                        android:textColor="@color/eko_text"
                        android:textColorHint="@color/eko_text_dim"
                        android:textSize="16sp"
                        android:background="@drawable/input_bg"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:imeOptions="actionSearch"
                        android:inputType="textUri"
                        android:singleLine="true"
                        android:layout_marginBottom="14dp" />

                    <!-- Buttons Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- PASTE button - large and visible -->
                        <Button
                            android:id="@+id/btnPaste"
                            android:layout_width="0dp"
                            android:layout_height="60dp"
                            android:layout_weight="1"
                            android:text="📋 لصق"
                            android:textSize="15sp"
                            android:textColor="@color/eko_text"
                            android:backgroundTint="@color/eko_surface2"
                            android:layout_marginEnd="8dp"
                            app:cornerRadius="12dp" />

                        <!-- CLEAR button -->
                        <Button
                            android:id="@+id/btnClear"
                            android:layout_width="0dp"
                            android:layout_height="60dp"
                            android:layout_weight="0.7"
                            android:text="🗑 مسح"
                            android:textSize="15sp"
                            android:textColor="@color/eko_text_dim"
                            android:backgroundTint="@color/eko_surface2"
                            android:layout_marginEnd="8dp"
                            app:cornerRadius="12dp" />

                        <!-- FETCH button - big red -->
                        <Button
                            android:id="@+id/btnFetch"
                            android:layout_width="0dp"
                            android:layout_height="60dp"
                            android:layout_weight="1.2"
                            android:text="🔍 بحث"
                            android:textSize="16sp"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/eko_accent"
                            app:cornerRadius="12dp" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ Platform chips hint ══ -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="🔴 YouTube"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:background="@drawable/chip_bg_red"
                        android:paddingHorizontal="12dp"
                        android:gravity="center"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="🎵 TikTok"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:background="@drawable/chip_bg_dark"
                        android:paddingHorizontal="12dp"
                        android:gravity="center"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="🐦 Twitter/X"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:background="@drawable/chip_bg_dark"
                        android:paddingHorizontal="12dp"
                        android:gravity="center"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="📘 Facebook"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:background="@drawable/chip_bg_dark"
                        android:paddingHorizontal="12dp"
                        android:gravity="center"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="🎭 SoundCloud"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:background="@drawable/chip_bg_dark"
                        android:paddingHorizontal="12dp"
                        android:gravity="center" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- ══ Loading Card ══ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLoading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardBackgroundColor="@color/eko_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp"
                    android:gravity="center">

                    <ProgressBar
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:indeterminateTint="@color/eko_accent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚙ جاري استخراج معلومات الفيديو…"
                        android:textColor="@color/eko_text_dim"
                        android:textSize="13sp"
                        android:layout_marginTop="14dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="مدعوم بمحرك NewPipe"
                        android:textColor="@color/eko_accent"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ Error Card ══ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardBackgroundColor="@color/eko_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="❌ خطأ"
                        android:textColor="@color/eko_error"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/eko_text_dim"
                        android:textSize="13sp"
                        android:layout_marginBottom="14dp" />

                    <Button
                        android:id="@+id/btnRetry"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="🔄 إعادة المحاولة"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/eko_accent"
                        app:cornerRadius="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ Video Info Card ══ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardBackgroundColor="@color/eko_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Thumbnail with rounded corners top -->
                    <ImageView
                        android:id="@+id/ivThumbnail"
                        android:layout_width="match_parent"
                        android:layout_height="210dp"
                        android:scaleType="centerCrop"
                        android:background="@color/eko_surface2" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Platform badge -->
                        <TextView
                            android:id="@+id/tvPlatform"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="YouTube"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:layout_marginBottom="10dp" />

                        <!-- Title -->
                        <TextView
                            android:id="@+id/tvVideoTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/eko_text"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-medium"
                            android:maxLines="3"
                            android:ellipsize="end"
                            android:layout_marginBottom="8dp" />

                        <!-- Author + Duration row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="18dp">

                            <TextView
                                android:id="@+id/tvAuthor"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text=""
                                android:textColor="@color/eko_text_dim"
                                android:textSize="13sp"
                                android:drawablePadding="4dp" />

                            <TextView
                                android:id="@+id/tvDuration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="@color/eko_accent"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium" />

                        </LinearLayout>

                        <!-- Action Buttons - big and clear -->
                        <Button
                            android:id="@+id/btnPlayInApp"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:text="▶  تشغيل الآن"
                            android:textSize="15sp"
                            android:textColor="@color/eko_accent"
                            android:backgroundTint="@color/eko_surface2"
                            android:layout_marginBottom="10dp"
                            app:cornerRadius="14dp" />

                        <Button
                            android:id="@+id/btnDownload"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:text="⬇  تحميل الفيديو"
                            android:textSize="15sp"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/eko_accent"
                            app:cornerRadius="14dp" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ Downloads Header ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:id="@+id/layoutDownloadsHeader"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/tvDownloadsHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📥 التحميلات"
                    android:textColor="@color/eko_text"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EKO ENGINE"
                    android:textColor="@color/eko_accent"
                    android:textSize="10sp"
                    android:letterSpacing="0.15" />

            </LinearLayout>

            <!-- ══ Downloads RecyclerView ══ -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDownloads"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
